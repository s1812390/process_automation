# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# =============================================================
# Oracle DB connection
# On production: point to your corporate Oracle server.
# Locally: overridden by docker-compose.override.yml (oracle-db container).
# =============================================================
ORACLE_HOST=your-oracle-host.company.com
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=ORCL
ORACLE_USER=scheduler_user
ORACLE_PASSWORD=change_me

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# Alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

TELEGRAM_BOT_TOKEN=
